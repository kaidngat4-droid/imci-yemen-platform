
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IMCI Yemen | منصة التدريب الطبي للرعاية التكاملية لصحة الطفل</title>
    <meta name="description" content="منصة IMCI اليمن - التدريب الطبي الاحترافي للرعاية التكاملية لصحة الطفل">
    <meta name="theme-color" content="#0f172a">
    <link rel="icon" type="image/png" href="images/favicon.png">
    <link href="https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&family=Cairo:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        :root{--p:#14b8a6;--pl:#5eead4;--g:#d4af37;--d:#0f172a;--l:#cbd5e1;--r:#CE1126}
        *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
        html{scroll-behavior:smooth}
        body{font-family:'Cairo',sans-serif;background:var(--d);color:#fff;padding-top:200px;min-height:100vh;transition:0.3s}
        .flag{display:flex;height:5px;position:fixed;top:0;left:0;right:0;z-index:10001}
        .fr{flex:1;background:var(--r)}.fw{flex:1;background:#fff}.fb{flex:1;background:#000}
        .top-bar{position:fixed;top:5px;left:0;right:0;z-index:10000;background:linear-gradient(180deg,#1a1a2e,#16213e);box-shadow:0 4px 20px rgba(0,0,0,0.5)}
        .brand{text-align:center;padding:20px}
        .brand img{width:90px;margin-bottom:8px}
        .brand h1{font-family:'Amiri',serif;color:var(--g);font-size:1.6rem}
        .brand h2{font-family:'Amiri',serif;color:#fff;font-size:1rem}
        .brand p{color:var(--pl);margin-top:6px;font-size:0.9rem}
        .nav{display:flex;gap:8px;justify-content:center;padding:10px;background:rgba(0,0,0,0.3);flex-wrap:wrap;border-top:1px solid rgba(212,175,55,0.2)}
        .nav a{color:var(--g);text-decoration:none;padding:6px 12px;font-weight:600;font-size:0.85rem;border-radius:8px;transition:0.15s}
        .nav a:hover{background:rgba(212,175,55,0.15)}
        .main{max-width:1000px;margin:auto;padding:20px}
        .hero{text-align:center;padding:30px 20px}
        .hero h2{font-family:'Amiri',serif;font-size:2.2rem;color:var(--pl)}
        .btn{display:inline-block;padding:12px 24px;border-radius:30px;text-decoration:none;font-weight:700;margin:6px;min-height:48px;transition:0.3s}
        .btn-t{background:var(--p);color:#fff}.btn-o{border:2px solid rgba(255,255,255,0.3);color:#fff}.btn-g{background:var(--g);color:#1a1a1a}
        .btn:hover{transform:translateY(-2px);box-shadow:0 8px 25px rgba(0,0,0,0.3)}
        .grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:20px;margin:25px 0}
        .card{background:rgba(255,255,255,0.06);border-radius:20px;padding:25px;text-align:center;text-decoration:none;color:#fff;display:block;transition:0.3s;opacity:0;transform:translateY(30px)}
        .card.visible{opacity:1;transform:translateY(0)}
        .card:hover{background:rgba(255,255,255,0.1);transform:translateY(-5px)!important}
        .card .icon{font-size:45px;margin-bottom:8px}.card h3{color:var(--pl)}
        .stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:15px;margin:25px 0}
        .stat{background:rgba(255,255,255,0.06);border-radius:16px;padding:20px;text-align:center;opacity:0;transform:translateY(30px);transition:0.6s}
        .stat.visible{opacity:1;transform:translateY(0)}
        .stat-num{font-size:28px;font-weight:900;color:var(--pl)}
        .sig{background:#0d2b1e;padding:16px;text-align:center;border-top:1px solid var(--g);margin-top:30px}
        .sig span{color:#888;font-size:0.7rem}.sig strong{color:var(--g)}
        .ctrl{position:fixed;top:210px;right:10px;z-index:9999;display:flex;flex-direction:column;gap:6px}
        .ctrl button{width:40px;height:40px;border-radius:50%;border:none;font-size:18px;cursor:pointer;box-shadow:0 4px 15px rgba(0,0,0,0.3);transition:0.3s;position:relative}
        .ctrl button:hover{transform:scale(1.1)}
        .ctrl button:hover::after{content:attr(aria-label);position:absolute;right:50px;top:50%;transform:translateY(-50%);background:#1a1a2e;color:#fff;padding:6px 12px;border-radius:6px;font-size:12px;white-space:nowrap}
        .sr{position:fixed;right:10px;bottom:130px;display:flex;flex-direction:column;gap:8px;z-index:9998}
        .sr a{width:44px;height:44px;border-radius:50%;display:flex;align-items:center;justify-content:center;text-decoration:none;font-size:20px;background:var(--p);color:#fff;box-shadow:0 4px 15px rgba(0,0,0,0.4);transition:0.3s;position:relative}
        .sr a:hover{transform:scale(1.1)}
        .sr a:hover::after{content:attr(aria-label);position:absolute;right:55px;background:#1a1a2e;color:#fff;padding:6px 12px;border-radius:6px;font-size:12px;white-space:nowrap}
        .sl{position:fixed;left:10px;bottom:130px;display:flex;flex-direction:column;gap:8px;z-index:9998}
        .sl a{width:44px;height:44px;border-radius:50%;display:flex;align-items:center;justify-content:center;text-decoration:none;font-size:20px;background:#7c3aed;color:#fff;box-shadow:0 4px 15px rgba(0,0,0,0.4);transition:0.3s;position:relative}
        .sl a:hover{transform:scale(1.1)}
        .sl a:hover::after{content:attr(aria-label);position:absolute;left:55px;background:#1a1a2e;color:#fff;padding:6px 12px;border-radius:6px;font-size:12px;white-space:nowrap}
        body.light-mode{--d:#f8fafc;color:#0f172a}
        body.light-mode .card,body.light-mode .stat{background:rgba(15,23,42,0.04);color:#0f172a}
        .toast{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%) scale(0.9);background:#1a1a2e;color:#fff;padding:12px 24px;border-radius:12px;font-weight:700;z-index:10004;opacity:0;transition:0.3s;pointer-events:none;border:1px solid var(--g)}
        .toast.show{opacity:1;transform:translate(-50%,-50%) scale(1)}
        @media(max-width:600px){body{padding-top:180px}.brand img{width:60px}.brand h1{font-size:1.2rem}.ctrl{top:190px}.sl,.sr{bottom:100px}}
    </style>
</head>
<body>
<a href="#main" style="position:absolute;top:-100px;left:50%;transform:translateX(-50%);background:var(--g);color:var(--d);padding:8px 24px;border-radius:12px;font-weight:700;text-decoration:none;z-index:10002;">تخطي إلى المحتوى</a>
<div class="flag"><div class="fr"></div><div class="fw"></div><div class="fb"></div></div>
<div class="top-bar">
    <div class="brand">
        <img src="images/yemen-eagle.png" alt="شعار الجمهورية اليمنية">
        <h1>الجمهورية اليمنية</h1>
        <h2>وزارة الصحة العامة والبيئة</h2>
        <p>🏥 منصة التدريب الطبي للرعاية التكاملية لصحة الطفل (IMCI)</p>
    </div>
    <div class="nav">
        <a href="">🏠 الرئيسية</a><a href="trainer.html">👨‍⚕️ المدرب</a><a href="admin.html">⚙️ المدير</a>
        <a href="report.html">📊 تقرير</a><a href="live-room.html">📹 بث</a><a href="https://kaidngat4-droid.github.io/imci-yemen-platform/protocol.html">📋 بروتوكولات</a><a href="https://kaidngat4-droid.github.io/imci-yemen-platform/quiz.html">✅ اختبار</a>
    </div>
</div>
<main id="main" class="main">
    <section class="hero">
        <h2>🏥 IMCI Yemen</h2>
        <p style="color:var(--l);margin-top:10px;">منصة التدريب الطبي للرعاية التكاملية لصحة الطفل</p>
        <div style="margin-top:20px;">
            <a href="trainer.html" class="btn btn-t">👨‍⚕️ لوحة المدرب</a>
            <a href="report.html" class="btn btn-o">📊 تقرير الأداء</a>
            <a href="live-room.html" class="btn btn-g">📹 البث المباشر</a>
        </div>
    </section>
    <div class="grid">
        <a href="https://kaidngat4-droid.github.io/imci-yemen-platform/age-calculator.html" class="card"><div class="icon">🧮</div><h3>حاسبة العمر</h3><p>حساب عمر الطفل</p></a>
        <a href="https://kaidngat4-droid.github.io/imci-yemen-platform/decision-tree.html" class="card"><div class="icon">🌳</div><h3>شجرة القرارات</h3><p>بروتوكول التقييم</p></a>
        <a href="https://kaidngat4-droid.github.io/imci-yemen-platform/protocol.html" class="card"><div class="icon">📋</div><h3>بروتوكولات</h3><p>6 بروتوكولات</p></a>
        <a href="live-room.html" class="card"><div class="icon">📹</div><h3>بث مباشر</h3><p>محاضرات تفاعلية</p></a>
        <a href="report.html" class="card"><div class="icon">📊</div><h3>تقرير</h3><p>تتبع التقدم</p></a>
        <a href="https://kaidngat4-droid.github.io/imci-yemen-platform/quiz.html" class="card"><div class="icon">✅</div><h3>اختبار</h3><p>تقييم تفاعلي</p></a>
    </div>
    <div class="stats">
        <div class="stat"><div class="stat-num">500+</div><div>متدرب</div></div>
        <div class="stat"><div class="stat-num">3</div><div>مستويات</div></div>
        <div class="stat"><div class="stat-num">30+</div><div>ساعة</div></div>
        <div class="stat"><div class="stat-num">88%</div><div>نجاح</div></div>
    </div>
</main>
<div class="ctrl">
    <button onclick="toggleDark()" id="db" style="background:#fbbf24;" aria-label="🌙 الوضع الليلي">🌙</button>
    <button onclick="changeFont(1)" style="background:var(--p);color:#fff;font-size:14px;font-weight:bold;" aria-label="تكبير الخط">A+</button>
    <button onclick="changeFont(-1)" style="background:var(--p);color:#fff;font-size:12px;font-weight:bold;" aria-label="تصغير الخط">A-</button>
</div>
<div class="sr">
    <a href="" aria-label="الرئيسية">🏠</a>
    <a href="https://kaidngat4-droid.github.io/imci-yemen-platform/quiz.html" aria-label="اختبار">✅</a>
    <a href="https://kaidngat4-droid.github.io/imci-yemen-platform/protocol.html" aria-label="بروتوكولات">📋</a>
    <a href="https://kaidngat4-droid.github.io/imci-yemen-platform/decision-tree.html" aria-label="شجرة القرارات">🌳</a>
</div>
<div class="sl">
    <a href="live-room.html" aria-label="بث مباشر">📹</a>
    <a href="report.html" aria-label="تقرير">📊</a>
    <a href="trainer.html" aria-label="مدرب">👨‍⚕️</a>
    <a href="admin.html" aria-label="مدير">⚙️</a>
</div>
<div id="toast" class="toast"></div>
<footer class="sig"><span>🌐 Engineered & Designed by</span><br><strong>Dr. Salah Al-Ahdal</strong></footer>
<script>
let fs=parseInt(localStorage.getItem('imci-font'))||16;
document.documentElement.style.fontSize=fs+'px';
function changeFont(d){fs+=d;if(fs<12)fs=12;if(fs>24)fs=24;document.documentElement.style.fontSize=fs+'px';localStorage.setItem('imci-font',fs);showToast('حجم الخط: '+fs+'px');}
function toggleDark(){document.body.classList.toggle('light-mode');let b=document.getElementById('db');let isLight=document.body.classList.contains('light-mode');b.textContent=isLight?'☀️':'🌙';b.setAttribute('aria-label',isLight?'☀️ الوضع النهاري':'🌙 الوضع الليلي');localStorage.setItem('imci-dark',isLight?'light':'dark');}
function showToast(m){let t=document.getElementById('toast');t.textContent=m;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),1500);}
if(localStorage.getItem('imci-dark')==='light'){document.body.classList.add('light-mode');document.getElementById('db').textContent='☀️';}
document.addEventListener('keydown',e=>{if(e.ctrlKey&&e.key==='t'){e.preventDefault();toggleDark();}});
let observer=new IntersectionObserver((e)=>{e.forEach(en=>{if(en.isIntersecting)en.target.classList.add('visible');});},{threshold:0.1});
document.querySelectorAll('.card,.stat').forEach(el=>observer.observe(el));
if('serviceWorker' in navigator){navigator.serviceWorker.register('sw.js');}
</script>
</body>
</html>
