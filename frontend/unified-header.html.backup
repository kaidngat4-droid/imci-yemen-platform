<link href="https://fonts.googleapis.com/css2?family=Amiri:ital,wght@0,400;0,700&family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<style>
.unified-header { background: linear-gradient(135deg, #0d2b1e, #1a3a4a); color: white; }
.unified-header .flag-bar { display: flex; height: 5px; }
.unified-header .flag-red { flex: 1; background: #CE1126; }
.unified-header .flag-white { flex: 1; background: #FFFFFF; }
.unified-header .flag-black { flex: 1; background: #000000; }
.unified-header .header-row { display: flex; align-items: center; justify-content: center; padding: 12px 20px; gap: 20px; flex-wrap: wrap; text-align: center; }
.unified-header .emblem { width: 60px; height: 60px; }
.unified-header .title-main { font-family: 'Amiri', serif; font-size: 1.4rem; color: #d4af37; font-weight: 700; margin: 0; }
.unified-header .title-sub { font-family: 'Amiri', serif; font-size: 1rem; color: #fff; margin: 2px 0; }
.unified-header .title-tag { font-size: 0.75rem; color: #a0c4d8; }
.unified-header .nav-bar { background: rgba(0,0,0,0.3); padding: 8px 20px; display: flex; gap: 15px; justify-content: center; flex-wrap: wrap; }
.unified-header .nav-link { color: #d4af37; text-decoration: none; font-weight: 600; font-size: 0.85rem; padding: 5px 10px; }
.unified-header .nav-link:hover { color: #fff; }
@media (max-width: 600px) {
  .unified-header .header-row { gap: 8px; padding: 8px; }
  .unified-header .emblem { width: 40px; height: 40px; }
  .unified-header .title-main { font-size: 1rem; }
  .unified-header .title-sub { font-size: 0.75rem; }
  .unified-header .nav-link { font-size: 0.7rem; padding: 3px 6px; }
}
</style>

<header class="unified-header">
    <div class="flag-bar">
        <div class="flag-red"></div>
        <div class="flag-white"></div>
        <div class="flag-black"></div>
    </div>
    <div class="header-row">
        <img src="images/yemen-emblem.png" alt="النسر الجمهوري" class="emblem" onerror="this.style.display='none'">
        <div>
            <h1 class="title-main">الجمهورية اليمنية</h1>
            <h2 class="title-sub">وزارة الصحة العامة والبيئة</h2>
            <p class="title-tag">منصة IMCI للرعاية التكاملية لصحة الطفل</p>
        </div>
    </div>
    <nav class="nav-bar">
        <a href="/" class="nav-link">🏠 الرئيسية</a>
        <a href="/dashboard" class="nav-link">📊 لوحة التحكم</a>
        <a href="/lesson" class="nav-link">📝 الدرس</a>
        <a href="/exam" class="nav-link">✅ اختبارات</a>
        <a href="/live-room" class="nav-link">📹 بث مباشر</a>
        <a href="/certificate" class="nav-link">🏆 شهادات</a>
        <a href="/admin" class="nav-link">🛡️ الإدارة</a>
    </nav>
</header>
