<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IMCI Yemen</title>
    <link rel="icon" type="image/png" href="images/favicon.png">
    <link href="https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        
        body { 
            font-family:'Cairo',sans-serif; 
            background:#0f172a; 
            color:#fff; 
            font-size:16px;
            padding-top: 200px;
        }
        
        .top-bar {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 10000;
            background: linear-gradient(180deg,#1a1a2e,#16213e);
            box-shadow: 0 4px 20px rgba(0,0,0,0.5);
        }
        
        .flag { display:flex; height:5px; }
        .flag-r { flex:1; background:#CE1126; } 
        .flag-w { flex:1; background:#fff; } 
        .flag-b { flex:1; background:#000; }
        
        .header { 
            text-align:center; 
            padding:20px; 
        }
        .header img { 
            width:90px; 
            margin-bottom:8px; 
        }
        .header h1 { 
            font-family:'Amiri',serif; 
            color:#d4af37; 
            font-size:1.6rem; 
        }
        .header h2 { 
            font-family:'Amiri',serif; 
            color:#fff; 
            font-size:1rem; 
        }
        .header p { 
            color:#5eead4; 
            margin-top:6px; 
            font-size:0.9rem; 
        }
        
        .nav { 
            display:flex; 
            gap:8px; 
            justify-content:center; 
            padding:10px; 
            background:rgba(0,0,0,0.3); 
            flex-wrap:wrap;
            border-top: 1px solid rgba(212,175,55,0.2);
        }
        .nav a { 
            color:#d4af37; 
            text-decoration:none; 
            padding:6px 12px; 
            font-weight:600; 
            font-size:0.85rem; 
            border-radius:8px; 
            transition:0.3s; 
        }
        .nav a:hover { 
            background:rgba(212,175,55,0.15); 
        }
        
        .container { 
            max-width:1000px; 
            margin:auto; 
            padding:20px; 
        }
        
        .hero { 
            text-align:center; 
            padding:30px 20px; 
        }
        .hero h2 { 
            font-family:'Amiri',serif; 
            font-size:2.2rem; 
            color:#5eead4; 
        }
        .btn { 
            display:inline-block; 
            padding:12px 24px; 
            border-radius:30px; 
            text-decoration:none; 
            font-weight:700; 
            margin:6px; 
            transition:0.3s; 
        }
        .btn-teal { background:#14b8a6; color:#fff; }
        .btn-outline { border:2px solid rgba(255,255,255,0.3); color:#fff; }
        .btn-gold { background:#d4af37; color:#1a1a1a; }
        
        .grid { 
            display:grid; 
            grid-template-columns:repeat(auto-fit,minmax(250px,1fr)); 
            gap:20px; 
            margin:25px 0; 
        }
        .card { 
            background:rgba(255,255,255,0.06); 
            border-radius:20px; 
            padding:25px; 
            text-align:center; 
            transition:0.3s; 
            text-decoration:none; 
            color:#fff; 
            display:block; 
        }
        .card:hover { 
            background:rgba(255,255,255,0.1); 
            transform:translateY(-5px); 
        }
        .card .icon { font-size:45px; margin-bottom:8px; }
        .card h3 { color:#5eead4; margin-bottom:6px; }
        
        .stats { 
            display:grid; 
            grid-template-columns:repeat(auto-fit,minmax(140px,1fr)); 
            gap:15px; 
            margin:25px 0; 
        }
        .stat { 
            background:rgba(255,255,255,0.06); 
            border-radius:16px; 
            padding:20px; 
            text-align:center; 
        }
        .stat-num { font-size:28px; font-weight:900; color:#5eead4; }
        
        .sig { 
            background:#0d2b1e; 
            padding:16px; 
            text-align:center; 
            border-top:1px solid #d4af37; 
            margin-top:30px; 
        }
        .sig span { color:#888; font-size:0.7rem; }
        .sig strong { color:#d4af37; }
        
        .sidebar { 
            position:fixed; 
            right:15px; 
            bottom:100px; 
            display:flex; 
            flex-direction:column; 
            gap:8px; 
            z-index:9999; 
        }
        .sidebar a { 
            width:40px; 
            height:40px; 
            border-radius:50%; 
            display:flex; 
            align-items:center; 
            justify-content:center; 
            text-decoration:none; 
            font-size:18px; 
            background:#14b8a6; 
            color:#fff; 
            box-shadow:0 4px 15px rgba(0,0,0,0.4); 
        }
        
        .ctrl { 
            position:fixed; 
            top:210px; 
            right:10px; 
            z-index:9999; 
            display:flex; 
            flex-direction:column; 
            gap:6px; 
        }
        .ctrl button { 
            width:36px; 
            height:36px; 
            border-radius:50%; 
            border:none; 
            font-size:16px; 
            cursor:pointer; 
            box-shadow:0 4px 15px rgba(0,0,0,0.3); 
        }
        
        @media(max-width:600px){ 
            body { padding-top: 180px; }
            .header img { width:60px; }
            .header h1 { font-size:1.2rem; }
            .header h2 { font-size:0.85rem; }
            .header p { font-size:0.8rem; }
            .nav a { font-size:0.75rem; padding:5px 8px; }
            .hero h2 { font-size:1.6rem; }
            .ctrl { top: 190px; }
        }
    </style>
</head>
<body>

<div class="top-bar">
    <div class="flag">
        <div class="flag-r"></div>
        <div class="flag-w"></div>
        <div class="flag-b"></div>
    </div>
    
    <div class="header">
        <img src="images/yemen-eagle.png" alt="شعار الجمهورية اليمنية">
        <h1>الجمهورية اليمنية</h1>
        <h2>وزارة الصحة العامة والبيئة</h2>
        <p>🏥 منصة التدريب الطبي للرعاية التكاملية لصحة الطفل (IMCI)</p>
    </div>
    
    <div class="nav">
        <a href="/">🏠 الرئيسية</a>
        <a href="/report.html">📊 تقرير</a>
        <a href="/live-room.html">📹 بث</a>
        <a href="/protocol.html">📋 بروتوكولات</a>
        <a href="/decision-tree.html">🌳 تقييم</a>
        <a href="/age-calculator.html">🧮 عمر</a>
    </div>
</div>

<div class="container">
    <div class="hero">
        <h2>🏥 IMCI Yemen</h2>
        <p style="color:#cbd5e1;font-size:1.1rem;margin-top:10px;">منصة التدريب الطبي للرعاية التكاملية لصحة الطفل</p>
        <div style="margin-top:20px;">
            <a href="/trainer.html" class="btn btn-teal">👨‍⚕️ لوحة المدرب</a>
            <a href="/report.html" class="btn btn-outline">📊 تقرير الأداء</a>
            <a href="/live-room.html" class="btn btn-gold">📹 البث المباشر</a>
        </div>
    </div>

    <div class="grid">
        <a href="/age-calculator.html" class="card">
            <div class="icon">🧮</div>
            <h3>حاسبة العمر</h3>
            <p>حساب عمر الطفل بالأشهر والأيام</p>
        </a>
        <a href="/decision-tree.html" class="card">
            <div class="icon">🌳</div>
            <h3>شجرة القرارات</h3>
            <p>بروتوكول التقييم التفاعلي</p>
        </a>
        <a href="/protocol.html" class="card">
            <div class="icon">📋</div>
            <h3>بروتوكولات العلاج</h3>
            <p>6 بروتوكولات IMCI كاملة</p>
        </a>
        <a href="/live-room.html" class="card">
            <div class="icon">📹</div>
            <h3>البث المباشر</h3>
            <p>محاضرات تفاعلية</p>
        </a>
        <a href="/report.html" class="card">
            <div class="icon">📊</div>
            <h3>تقرير الأداء</h3>
            <p>تتبع التقدم والشهادات</p>
        </a>
        <a href="/report.html" class="card">
            <div class="icon">📊</div>
            <h3>تقرير الأداء</h3>
            <p>تتبع التقدم والنتائج</p>
        </a>
    </div>

    <div class="stats">
        <div class="stat"><div class="stat-num">500+</div><div>متدرب</div></div>
        <div class="stat"><div class="stat-num">3</div><div>مستويات</div></div>
        <div class="stat"><div class="stat-num">30+</div><div>ساعة</div></div>
        <div class="stat"><div class="stat-num">88%</div><div>نجاح</div></div>
    </div>
</div>

<div class="sidebar">
    <a href="/" title="الرئيسية">🏠</a>
    <a href="/age-calculator.html" title="حاسبة العمر">🧮</a>
    <a href="/decision-tree.html" title="شجرة القرارات">🌳</a>
    <a href="/protocol.html" title="البروتوكولات">📋</a>
    <a href="/quiz.html" title="اختبارات" style="background:#d4af37;color:#1a1a1a;">✅</a>
</div>

<div class="ctrl">
    <button onclick="toggleDark()" style="background:#fbbf24;">🌙</button>
    <button onclick="changeFont(1)" style="background:#14b8a6;color:#fff;font-size:14px;font-weight:bold;">A+</button>
    <button onclick="changeFont(-1)" style="background:#14b8a6;color:#fff;font-size:12px;font-weight:bold;">A-</button>
</div>

<div class="sig">
    <span>🌐 Engineered & Designed by</span><br>
    <strong>Dr. Salah Al-Ahdal</strong><br>
    <span style="color:#7cb342;font-size:0.65rem;">Full-Stack Developer & Medical Systems Architect</span>
</div>

<script>
let fs = 16;
function changeFont(d) {
    fs += d; if(fs < 12) fs = 12; if(fs > 24) fs = 24;
    document.body.style.fontSize = fs + 'px';
}
function toggleDark() {
    document.body.style.background = document.body.style.background === 'rgb(255, 255, 255)' ? '#0f172a' : '#fff';
    document.body.style.color = document.body.style.color === 'rgb(15, 23, 42)' ? '#fff' : '#0f172a';
}
</script>
</body>
</html>
