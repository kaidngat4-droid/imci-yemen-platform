<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>تسجيل الدخول - IMCI Yemen</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        body { font-family:'Cairo',sans-serif; background: radial-gradient(circle at top,#14b8a6,transparent 30%), radial-gradient(circle at bottom,#0f766e,transparent 30%),#0f172a; min-height:100vh; display:flex; align-items:center; justify-content:center; padding:20px; }
        .box { background:rgba(255,255,255,0.06); backdrop-filter:blur(20px); border:1px solid rgba(255,255,255,0.1); border-radius:24px; padding:35px; max-width:400px; width:100%; text-align:center; }
        .box img { width:80px; margin-bottom:10px; }
        .box h2 { color:#d4af37; font-family:'Amiri',serif; margin:5px 0; }
        .box p { color:#cbd5e1; margin-bottom:20px; font-size:0.9rem; }
        input { width:100%; padding:14px; margin:8px 0; background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.15); border-radius:14px; color:white; font-size:16px; font-family:'Cairo',sans-serif; }
        input:focus { outline:none; border-color:#5eead4; }
        .btn { width:100%; padding:14px; margin-top:12px; background:linear-gradient(135deg,#14b8a6,#0d9488); color:white; border:none; border-radius:14px; font-size:18px; font-weight:700; cursor:pointer; }
        .btn:hover { transform:translateY(-2px); }
        #msg { margin-top:10px; font-weight:600; }
    </style>
</head>
<body>
<div class="box">
    <img src="images/yemen-eagle.png" alt="شعار" onerror="this.style.display='none'">
    <h2>الجمهورية اليمنية</h2>
    <p>وزارة الصحة العامة والبيئة</p>
    <input type="email" id="email" placeholder="البريد الإلكتروني" value="Kaidngat4@gmail.com">
    <input type="password" id="password" placeholder="كلمة المرور" value="Yemen2026!">
    <button class="btn" onclick="login()">🚪 دخول</button>
    <p id="msg"></p>
</div>
<script>
async function login() {
    const m=document.getElementById('msg'); m.textContent='⏳ جاري...'; m.style.color='#5eead4';
    try {
        const r=await fetch('http://localhost:3000/api/v1/auth/login',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({email:document.getElementById('email').value,password:document.getElementById('password').value})});
        const d=await r.json();
        if(d.success){localStorage.setItem('token',d.token);localStorage.setItem('user',JSON.stringify(d.user));m.textContent='✅ مرحباً!';m.style.color='#4ade80';setTimeout(()=>location.href='/dashboard',1000);}
        else{m.textContent='❌ '+d.error;m.style.color='#f87171';}
    }catch(e){m.textContent='❌ فشل الاتصال - تأكد أن المنصة تعمل';m.style.color='#f87171';}
}
document.getElementById('password').addEventListener('keypress',function(e){if(e.key==='Enter')login();});
</script>
</body>
</html>
