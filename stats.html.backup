<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>الإحصائيات - IMCI Yemen</title>
    <link href="https://fonts.googleapis.com/css2?family=Amiri:ital,wght@0,400;0,700&family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet">
    <script src="notifications.js"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Amiri', 'Cairo', serif; background: #f8fafc; }
        .container { max-width: 1100px; margin: 30px auto; padding: 20px; }
        h1 { color: #0d9488; text-align: center; margin-bottom: 30px; font-size: 2rem; }
        .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-bottom: 30px; }
        .stat-card { background: white; border-radius: 16px; padding: 30px; text-align: center; box-shadow: 0 4px 15px rgba(0,0,0,0.08); transition: transform 0.3s; }
        .stat-card:hover { transform: translateY(-5px); }
        .stat-icon { font-size: 45px; margin-bottom: 10px; }
        .stat-value { font-size: 40px; font-weight: 900; color: #0d9488; }
        .stat-label { color: #64748b; font-size: 14px; margin-top: 5px; }
        .chart-bar { background: #e2e8f0; height: 20px; border-radius: 10px; overflow: hidden; margin: 10px 0; }
        .chart-fill { height: 100%; border-radius: 10px; background: linear-gradient(90deg, #0d9488, #2dd4bf); }
        .card { background: white; border-radius: 16px; padding: 25px; margin-bottom: 20px; box-shadow: 0 4px 15px rgba(0,0,0,0.08); }
        table { width: 100%; border-collapse: collapse; }
        th { background: #f1f5f9; padding: 12px; text-align: right; color: #0d9488; }
        td { padding: 12px; border-bottom: 1px solid #e2e8f0; }
        .btn { display: inline-block; padding: 12px 25px; background: #0d9488; color: white; border-radius: 25px; text-decoration: none; font-weight: bold; }
    </style>
</head>
<body>

<div class="container">
    <h1>📊 إحصائيات المنصة</h1>
    
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon">👥</div>
            <div class="stat-value">6</div>
            <div class="stat-label">متدرب مسجل</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">📚</div>
            <div class="stat-value">3</div>
            <div class="stat-label">دورات تدريبية</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">📹</div>
            <div class="stat-value">3</div>
            <div class="stat-label">محاضرات مباشرة</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">🏆</div>
            <div class="stat-value">88%</div>
            <div class="stat-label">نسبة النجاح</div>
        </div>
    </div>

    <div class="card">
        <h3>📊 تقدم المتدربين</h3>
        <table>
            <tr><th>المتدرب</th><th>التقدم</th><th>الدرجة</th></tr>
            <tr><td>د. محمد اليمني</td><td><div class="chart-bar"><div class="chart-fill" style="width:65%"></div></div>65%</td><td>78%</td></tr>
            <tr><td>د. عبد الهادي</td><td><div class="chart-bar"><div class="chart-fill" style="width:30%"></div></div>30%</td><td>85%</td></tr>
            <tr><td>د. صلاح الأهدل</td><td><div class="chart-bar"><div class="chart-fill" style="width:100%"></div></div>100%</td><td>95%</td></tr>
        </table>
    </div>

    <div class="card">
        <h3>📈 نشاط المنصة</h3>
        <table>
            <tr><th>النشاط</th><th>العدد</th></tr>
            <tr><td>✅ اختبارات مكتملة</td><td>45</td></tr>
            <tr><td>📹 محاضرات محضورة</td><td>120</td></tr>
            <tr><td>🏆 شهادات مصدرة</td><td>15</td></tr>
            <tr><td>💬 رسائل دردشة</td><td>230</td></tr>
        </table>
    </div>

    <a href="/dashboard" class="btn">← العودة للوحة التحكم</a>
</div>

<script>
    IMCI_Notifications.show('مرحباً بك في لوحة الإحصائيات! 📊', 'success');
</script>

</body>
</html>
